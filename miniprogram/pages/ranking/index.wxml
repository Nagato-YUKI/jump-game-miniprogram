<!--pages/ranking/index.wxml-->
<view class="ranking-container">
  <!-- 顶部标签 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'global' ? 'active' : ''}}" bindtap="switchTab" data-tab="global">
      全球排行
    </view>
  </view>

  <!-- 排行榜列表 -->
  <view class="ranking-list" wx:if="{{rankingList.length > 0}}">
    <view class="ranking-item {{item.isMe ? 'is-me' : ''}}" wx:for="{{rankingList}}" wx:key="index">
      <view class="rank-num">
        <text wx:if="{{index < 3}}" class="rank-medal">{{index === 0 ? '🥇' : index === 1 ? '🥈' : '🥉'}}</text>
        <text wx:else class="rank-text">{{index + 1}}</text>
      </view>
      <view class="rank-avatar">
        <view class="avatar-placeholder">{{index + 1}}</view>
      </view>
      <view class="rank-info">
        <text class="rank-name">玩家{{item._id ? item._id.slice(-4) : index + 1}}</text>
        <text class="rank-level">关卡 {{item.level || 1}}</text>
      </view>
      <view class="rank-score">
        <text class="score-num">{{item.score}}</text>
        <text class="score-label">分</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && rankingList.length === 0}}">
    <text class="empty-text">暂无排行数据</text>
    <text class="empty-hint">快去游戏创造纪录吧！</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 我的排名 -->
  <view class="my-rank" wx:if="{{myBest !== null}}">
    <view class="my-rank-label">我的最高分</view>
    <view class="my-rank-score">{{myBest}}</view>
  </view>
</view>
